@page "/login"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout LoginLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject VikashIronix_WebUI.Services.AuthServices.Interfaces.IAuthService AuthService

<PageTitle>Secure Login - Vikash Iron Executive Suite</PageTitle>

<div class="login-page">
    <div class="login-card">
        <!-- Brand Header -->
        <div class="brand-header">
            <h1 class="brand-title">VIKASH IRON</h1>
            <div class="brand-subtitle">EXECUTIVE SUITE</div>
        </div>

        <div class="mb-6">
            <MudText Typo="Typo.h6" Style="font-weight: 800; color: #fff;">Secure Access</MudText>
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5);">Infrastructure surveillance monitored.</MudText>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMsg))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4 rounded-lg" Style="background: rgba(244, 67, 54, 0.1); color: #f44336; border: 1px solid rgba(244, 67, 54, 0.2);">
                @ErrorMsg
            </MudAlert>
        }

        <MudStack Spacing="3">
            <!-- Username field -->
            <div>
                <label class="input-label">Username or Email</label>
                <MudTextField @bind-Value="Email"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Placeholder="admin@vikashiron.com"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Margin="Margin.None"
                              FullWidth="true"
                              Class="glass-input" />
            </div>

            <!-- Password field -->
            <div>
                <label class="input-label">Security Credential</label>
                <MudTextField @bind-Value="Password"
                              Variant="Variant.Outlined"
                              InputType="@PwdType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@PwdIcon"
                              OnAdornmentClick="TogglePassword"
                              Margin="Margin.None"
                              FullWidth="true"
                              Class="glass-input" />
            </div>

            <!-- Remember + Forgot -->
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 8px;">
                <MudCheckBox T="bool" @bind-Value="KeepSession" Dense="true" Color="Color.Primary">
                    <span style="font-size: 0.8rem; color: rgba(255,255,255,0.7); font-weight: 600;">Stay Authenticated</span>
                </MudCheckBox>
                <MudLink Href="/forgot-password" Underline="Underline.None" Style="font-size: 0.8rem; font-weight: 700; color: #6ee591;">Reset Access?</MudLink>
            </div>

            <!-- Login Button -->
            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       OnClick="HandleLogin"
                       Class="login-button"
                       Disabled="IsLoading">
                @if (IsLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-3" />
                    <span>VERIFYING...</span>
                }
                else
                {
                    <span>INITIALIZE SESSION</span>
                }
            </MudButton>

            <!-- System Status -->
            <div style="text-align: center;">
                <div class="status-badge">
                    <div class="status-dot"></div>
                    <span class="status-text">Network Integrity Optimal</span>
                </div>
            </div>
        </MudStack>
    </div>

    <!-- Footer Links -->
    <div class="footer-links">
        <a href="#" class="footer-link">Security</a>
        <a href="#" class="footer-link">Privacy</a>
        <a href="#" class="footer-link">Status</a>
        <span class="footer-link" style="opacity: 0.5;">v4.0.0-PRO</span>
    </div>
</div>

@code {
    string Email = "";
    string Password = "";
    bool KeepSession = false;
    bool IsLoading = false;
    string ErrorMsg = "";
    InputType PwdType = InputType.Password;
    string PwdIcon = Icons.Material.Filled.VisibilityOff;

    void TogglePassword()
    {
        PwdType = PwdType == InputType.Password ? InputType.Text : InputType.Password;
        PwdIcon = PwdType == InputType.Password ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    }

    async Task HandleLogin()
    {
        ErrorMsg = "";
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMsg = "Please enter your credentials.";
            return;
        }
        IsLoading = true;
        
        var request = new VikashIronix_WebUI.Services.AuthServices.UserLoginRequest 
        { 
            EmailId = Email, 
            Password = Password, 
            // LoginDevice = "Web" 
        };
        
        var response = await AuthService.UserLoginAsync(request);
        
        if (response != null && !string.IsNullOrWhiteSpace(response.Token))
        {
            var uri = $"/account/callback?token={response.Token}&isPersistent={KeepSession}";
            Nav.NavigateTo(uri, forceLoad: true);
        }
        else
        {
            ErrorMsg = "Access denied. Invalid credentials. This attempt has been logged.";
        }
        IsLoading = false;
    }
}