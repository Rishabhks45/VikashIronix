@page "/billing/create"
@rendermode InteractiveServer
@using SharedKernel.DTOs.Customers
@using SharedKernel.DTOs.Inventory
@using SharedKernel.DTOs.Billing
@using VikashIronix_WebUI.Services.Customers
@using VikashIronix_WebUI.Services.Inventory
@using VikashIronix_WebUI.Services.Bills
@inject ICustomerService CustomerService
@inject IInventoryService InventoryService
@inject IBillService BillService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@using VikashIronix_WebUI.Services.Users
@inject IUserService UserService

<PageTitle>Create Invoice - Vikash Iron Invoicing</PageTitle>

<PageTitle>Create Invoice - Vikash Iron Management</PageTitle>

<style>
    .billing-root { 
        padding: 20px; 
        background: var(--mud-palette-background-grey);
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
    }
    .main-canvas { 
        max-width: 1440px; 
        margin: 0 auto; 
    }
    
    .terra-card { 
        background: var(--mud-palette-surface); 
        border-radius: 16px; 
        box-shadow: 0 2px 15px rgba(0,0,0,0.02); 
        border: 1px solid var(--mud-palette-divider);
        padding: 20px;
        height: 100%;
        overflow: hidden;
    }
    
    .section-headline { 
        font-size: 0.6rem; 
        font-weight: 800; 
        color: var(--mud-palette-text-secondary); 
        letter-spacing: 0.12em; 
        text-transform: uppercase; 
        margin-bottom: 12px; 
        display: block; 
    }

    .valuation-label { 
        font-size: 0.65rem; 
        font-weight: 800; 
        color: var(--mud-palette-text-secondary); 
        letter-spacing: 0.05em; 
        text-transform: uppercase;
        line-height: 1.1;
    }

    .valuation-amount { 
        font-family: 'Literata', serif; 
        font-weight: 900; 
        font-size: clamp(2rem, 4vw, 3.2rem); 
        color: var(--mud-palette-primary); 
        letter-spacing: -0.05em; 
        line-height: 1;
        margin-top: 4px;
        word-break: break-all;
    }

    .audit-summary-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px dashed var(--mud-palette-divider);
    }
    .audit-summary-label { color: var(--mud-palette-text-secondary); font-weight: 500; font-size: 0.95rem; }
    .audit-summary-value { color: var(--mud-palette-text-primary); font-weight: 700; font-family: monospace; font-size: 0.95rem; }

    .material-row {
        transition: all 0.2s ease;
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .material-row:hover { background: var(--mud-palette-action-default-hover); }

    .sticky-audit-node {
        position: sticky;
        top: 12px;
    }

    .btn-terra-primary {
        background: var(--mud-palette-primary) !important;
        color: var(--mud-palette-primary-text) !important;
        border-radius: 8px !important;
        padding: 8px 24px !important;
        font-weight: 800 !important;
        text-transform: none !important;
    }
    .btn-terra-ghost {
        color: var(--mud-palette-primary) !important;
        border-radius: 8px !important;
        font-weight: 700 !important;
        text-transform: none !important;
    }
    
    .invoice-preview-card {
        background: white; 
        color: #1e293b; 
        border-radius: 8px; 
        overflow: hidden; 
        position: relative; 
        border: 2px solid var(--mud-palette-primary); 
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
</style>

<div class="billing-root">
    <div class="main-canvas">
        <MudGrid Spacing="4">
            <!-- Left Side: Transaction Inputs -->
            <MudItem xs="12" lg="8">
                <header class="mb-4" style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px;">
                    <div>
                        <MudText Typo="Typo.h5" Style="font-family: 'Literata', serif; font-weight: 900; letter-spacing: -0.02em;" Color="Color.Default">Transaction Audit</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Synchronized fiscal auditing & warehouse allocation.</MudText>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        @if (ActiveBillId != null)
                        {
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" OnClose="StartNewTransaction">EDITING DRAFT: @GeneratedBillNumber</MudChip>
                        }
                        <MudButton StartIcon="@Icons.Material.Filled.Storefront" Variant="@(IsRetailMode ? Variant.Filled : Variant.Outlined)" Color="Color.Warning" OnClick="ToggleRetailMode" Size="Size.Small" Class="mr-2">@(IsRetailMode ? "Khudra Mode: ACTIVE" : "Retail Sale (Khudra)")</MudButton>
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" Color="Color.Primary" OnClick="StartNewTransaction" Size="Size.Small">New Transaction</MudButton>
                    </div>
                </header>

                <MudStack Spacing="3">
                    <!-- Entity Informatics -->
                    <div class="terra-card">
                        <span class="section-headline">Entity Informatics</span>
                        <MudGrid Spacing="2">
                            @if (!IsRetailMode)
                            {
                                <MudItem xs="12" md="6">
                                    <MudAutocomplete T="CustomerDto"
                                                    Label="Registered Entity / Shop Name"
                                                    Value="SelectedCustomer"
                                                    ValueChanged="OnCustomerSelected"
                                                    SearchFunc="SearchCustomers"
                                                    ToStringFunc="@(c => c?.ShopName ?? "")"
                                                    Variant="Variant.Filled"
                                                    Underline="false"
                                                    Dense="true"
                                                    AdornmentIcon="@Icons.Material.Filled.Search"
                                                    Style="background: var(--mud-palette-background-grey); border-radius: 8px;"
                                                    Placeholder="Type entity or shop name..." />
                                </MudItem>
                            }
                            else
                            {
                                <MudItem xs="12" md="4">
                                    <MudTextField Label="Retail Shop Name (नकद दुकान)" @bind-Value="RetailShopName" Variant="Variant.Filled" Underline="false" Dense="true" Style="background: rgba(255,152,0,0.05); border-radius: 8px;" Placeholder="e.g. KHUDRA SALE..." />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Label="Customer Name (नाम)" @bind-Value="RetailCustomerName" Variant="Variant.Filled" Underline="false" Dense="true" Style="background: rgba(255,152,0,0.05); border-radius: 8px;" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Label="Phone (मोबाइल)" @bind-Value="RetailPhone" Variant="Variant.Filled" Underline="false" Dense="true" Style="background: rgba(255,152,0,0.05); border-radius: 8px;" />
                                </MudItem>
                            }
                            
                            <MudItem xs="6" md="3">
                                <MudDatePicker Label="Fiscal Audit Date" @bind-Date="BillDate" Variant="Variant.Filled" Underline="false" Dense="true" Style="background: var(--mud-palette-background-grey); border-radius: 8px;" />
                            </MudItem>
                            <MudItem xs="6" md="3" />
                            
                            @if (SelectedCustomer != null && !IsRetailMode)
                            {
                                <MudItem xs="12">
                                    <div style="background: var(--mud-palette-background-grey); border: 1px solid var(--mud-palette-divider); padding: 12px; border-radius: 8px; display: flex; align-items: center; gap: 12px;">
                                        <div style="width: 32px; height: 32px; background: var(--mud-palette-primary); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--mud-palette-primary-text); font-weight: 900; font-size: 0.9rem;">
                                            @SelectedCustomer.ShopName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.body2" Style="font-weight: 900;">@SelectedCustomer.ShopName</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Contact: @SelectedCustomer.CustomerName · @SelectedCustomer.PhoneNumber</MudText>
                                        </div>
                                    </div>
                                </MudItem>
                            }
                        </MudGrid>
                    </div>

                    <!-- Line Items -->
                    <div class="terra-card" style="padding: 0;">
                        <div style="padding: 16px 20px; border-bottom: 2px solid var(--mud-palette-divider); display: flex; justify-content: space-between; align-items: center;">
                            <span class="section-headline" style="margin-bottom: 0;">Trade Ledger Snapshot</span>
                            <MudSwitch @bind-Value="IncludeGST" Color="Color.Primary" Label="GST Audit" Style="font-weight: 700; font-size: 0.6rem;" />
                        </div>
                        
                        <div style="padding: 12px 20px;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr style="text-align: left; border-bottom: 1px solid var(--mud-palette-divider);">
                                        <th style="padding: 12px 10px; font-size: 0.6rem; font-weight: 900; color: var(--mud-palette-text-secondary); text-transform: uppercase;">Resource Description</th>
                                        <th style="padding: 12px 10px; font-size: 0.6rem; font-weight: 900; color: var(--mud-palette-text-secondary); text-transform: uppercase; width: 100px;">Weight</th>
                                        <th style="padding: 12px 10px; font-size: 0.6rem; font-weight: 900; color: var(--mud-palette-text-secondary); text-transform: uppercase; width: 100px;">Rate</th>
                                        <th style="padding: 12px 10px; font-size: 0.6rem; font-weight: 900; color: var(--mud-palette-text-secondary); text-transform: uppercase; text-align: right; width: 120px;">Total</th>
                                        <th style="padding: 12px 10px; width: 40px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in BillRows)
                                    {
                                        <tr class="material-row">
                                            <td style="padding: 4px 10px;">
                                                <MudAutocomplete T="MaterialDto"
                                                                 Value="row.SelectedMaterial"
                                                                 ValueChanged="@(m => OnMaterialSelected(row, m))"
                                                                 SearchFunc="SearchMaterials"
                                                                 ToStringFunc="@(m => m == null ? "" : $"{m.Name} ({m.Shape})")"
                                                                 Variant="Variant.Text"
                                                                 Placeholder="Start typing resource..."
                                                                 Dense="true" />
                                            </td>
                                            <td style="padding: 4px 10px;">
                                                <MudNumericField T="decimal" 
                                                                Value="row.Quantity" 
                                                                ValueChanged="@(v => { row.Quantity = v; RecalcRow(row); })" 
                                                                Variant="Variant.Text" 
                                                                HideSpinButtons="true" 
                                                                Style="@(row.SelectedMaterial != null && row.Quantity > row.SelectedMaterial.StockMT ? "font-weight: 900; color: var(--mud-palette-error);" : "font-weight: 700;")" 
                                                                Error="@(row.SelectedMaterial != null && row.Quantity > row.SelectedMaterial.StockMT)"
                                                                ErrorText="Exceeds stock"
                                                                Dense="true" />
                                            </td>
                                            <td style="padding: 4px 10px;">
                                                <MudNumericField T="decimal" Value="row.UnitPrice" ValueChanged="@(v => { row.UnitPrice = v; RecalcRow(row); })" Variant="Variant.Text" HideSpinButtons="true" Style="font-weight: 700;" Dense="true" />
                                            </td>
                                            <td style="padding: 4px 10px; text-align: right;">
                                                <MudText Typo="Typo.body2" Style="font-weight: 700; font-family: monospace;">₹ @row.TotalPrice.ToString("N0")</MudText>
                                            </td>
                                            <td style="padding: 4px 10px;">
                                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick="() => RemoveRow(row)" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            <div style="padding: 12px; text-align: center;">
                                <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Text" OnClick="AddRow" Style="font-weight: 700; text-transform: none; font-size: 0.75rem;">Insert Audit Line</MudButton>
                            </div>
                        </div>
                    </div>

                    <!-- Supplemental Modals -->
                    <div class="terra-card">
                        <span class="section-headline" style="margin-bottom: 8px;">Operational Logistics</span>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudTextField Label="Bhada Amount" @bind-Value="BhadaAmount" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocalShipping" AdornmentColor="Color.Primary" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="GSTIN / Remarks" @bind-Value="GstinValue" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Notes" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div style="display: flex; gap: 12px; margin-top: 8px;">
                        <MudButton Variant="Variant.Filled" OnClick="GenerateInvoice" Disabled="IsSaving" Class="btn-terra-primary" StartIcon="@Icons.Material.Filled.DatasetLinked">Commit Final Audit</MudButton>
                        <MudButton Variant="Variant.Text" OnClick="SaveAsDraft" Disabled="IsSaving" Class="btn-terra-ghost">Archive Draft</MudButton>
                        @if (!string.IsNullOrEmpty(GeneratedBillNumber))
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="DownloadBill" StartIcon="@Icons.Material.Filled.DownloadDone" Style="border-radius: 8px; font-weight: 800; padding: 8px 20px;">Download Documentation</MudButton>
                        }
                    </div>
                </MudStack>
            </MudItem>

            <!-- Right Side: Sticky Audit Node -->
            <MudItem xs="12" lg="4">
                <div class="sticky-audit-node">
                    <div class="terra-card">
                        <span class="section-headline">Audit Summary</span>
                        
                        <div class="audit-summary-item">
                            <span class="audit-summary-label">Aggregate Base</span>
                            <span class="audit-summary-value">₹ @SubTotal.ToString("N0")</span>
                        </div>

                        <div class="audit-summary-item">
                            <span class="audit-summary-label">Logistics (Bhada)</span>
                            <span class="audit-summary-value">₹ @BhadaAmount.ToString("N0")</span>
                        </div>

                        @if (LabourAmount > 0)
                        {
                            <div class="audit-summary-item">
                                <span class="audit-summary-label">Operational Labour</span>
                                <span class="audit-summary-value">₹ @LabourAmount.ToString("N0")</span>
                            </div>
                        }

                        <hr style="margin: 16px 0; border: none; border-top: 1px dashed var(--mud-palette-divider);" />

                        <div style="display: flex; gap: 20px; align-items: center;">
                            <div class="valuation-label" style="writing-mode: vertical-rl; transform: rotate(180deg); display: flex; align-items: center; justify-content: center;">
                                FINAL<br/>VALUATION
                            </div>
                            <div style="flex-grow: 1; overflow: hidden;">
                                <div style="display: flex; align-items: flex-start; gap: 6px;">
                                    <span style="font-family: 'Literata', serif; font-size: 1.8rem; color: var(--mud-palette-primary); font-weight: 900; line-height: 1;">₹</span>
                                    <div class="valuation-amount">@Math.Round(GrandTotal).ToString("N0")</div>
                                </div>
                            </div>
                        </div>

                        <!-- Real-time Payment Realization -->
                        <div style="margin-top: 16px; background: var(--mud-palette-background-grey); padding: 16px; border-radius: 12px; border: 1px solid var(--mud-palette-divider);">
                            <span class="section-headline" style="font-size: 0.55rem; margin-bottom: 8px;">Collection Breakdown</span>
                            <MudGrid Spacing="2">
                                <MudItem xs="6">
                                    <MudNumericField T="decimal" Label="CASH PAYMENT (नकद)" @bind-Value="CashAmount" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" Style="font-family: monospace; font-weight: 800; color: #f59e0b;" Dense="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Payments" />
                                </MudItem>
                                <MudItem xs="6">
                                    <MudNumericField T="decimal" Label="A/C PAYMENT (बैंक)" @bind-Value="AccountAmount" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" Style="font-family: monospace; font-weight: 800; color: var(--mud-palette-success);" Dense="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountBalance" />
                                </MudItem>
                            </MudGrid>
                            
                            <div style="display: flex; gap: 8px; margin-top: 12px;">
                                <MudButton Size="Size.Small" OnClick='() => { CashAmount = GrandTotal; AccountAmount = 0; }' Variant="Variant.Text" Color="Color.Primary" Style="font-size: 0.65rem; font-weight: 800;">Full Cash</MudButton>
                                <MudButton Size="Size.Small" OnClick='() => { CashAmount = 0; AccountAmount = GrandTotal; }' Variant="Variant.Text" Color="Color.Success" Style="font-size: 0.65rem; font-weight: 800;">Full A/C</MudButton>
                                <MudSpacer />
                                <MudButton Size="Size.Small" 
                                           Variant="Variant.Filled" 
                                           Color="@(BalanceDue > 0 ? Color.Error : Color.Dark)" 
                                           DisableElevation="true"
                                           Style="font-weight: 900; font-size: 0.7rem; border-radius: 6px; padding: 4px 12px;"> 
                                    TOTAL DUES: ₹ @BalanceDue.ToString("N0")
                                </MudButton>
                            </div>

                            @if (BalanceDue > 0)
                            {
                                <div style="margin-top: 16px; padding: 16px; background: #fff; border: 1px dashed #673ab7; border-radius: 12px; text-align: center; box-shadow: 0 4px 12px rgba(103, 58, 183, 0.1);">
                                    <MudText Typo="Typo.caption" Style="color: #673ab7; font-weight: 950; display: block; margin-bottom: 8px; letter-spacing: 1px;">DIGITAL SETTLEMENT (UPI)</MudText>
                                    <img src="@($"https://api.qrserver.com/v1/create-qr-code/?size=140x140&data=upi://pay?pa=risham123sharma@ybl%26pn=Vikash%20Iron%26am={BalanceDue}%26cu=INR")" alt="UPI QR" style="width: 140px; height: 140px; border-radius: 8px;" />
                                    <MudText Typo="Typo.body2" Style="font-family: 'JetBrains Mono', monospace; font-weight: 900; margin-top: 12px; color: #1e293b; font-size: 0.75rem;">risham123sharma@ybl</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #64748b; font-weight: 700; display: block; margin-top: 4px;">Verified: Rishabh Kumar Sharma</MudText>
                                </div>
                            }
                        </div>

                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Default" 
                                   OnClick="TogglePreview" 
                                   FullWidth="true" 
                                   StartIcon="@(ShowPreview ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                   Style="margin-top: 24px; border-radius: 12px; padding: 12px; background: var(--mud-palette-action-default-hover); color: var(--mud-palette-text-primary); font-weight: 800; font-size: 0.75rem;">
                            @(ShowPreview ? "COLLAPSE AUDIT" : "INSPECT INVOICE")
                        </MudButton>

                        @if (ShowPreview)
                        {
                            <div class="invoice-preview-card mt-4">
                                <div style="padding: 16px;">
                                    <!-- Fiscal Header -->
                                    <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #1e293b; padding-bottom: 8px; margin-bottom: 12px;">
                                        <div>
                                            <div style="font-size: 5px; color: #64748b; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em;">TAX INVOICE</div>
                                            <div style="font-weight: 900; font-size: 10px; color: #1e293b;">VIKASH IRON AND STEEL</div>
                                            <div style="font-size: 5px; color: #64748b;">EKMA PARSA ROAD · SESSION 2026-27</div>
                                        </div>
                                        <div style="text-align: right;">
                                            <div style="font-size: 9px; font-weight: 900; color: var(--mud-palette-primary);">@(GeneratedBillNumber ?? "DRAFT")</div>
                                            <div style="font-size: 5px; color: #64748b;">@BillDate?.ToString("dd MMM yyyy")</div>
                                            @if (BalanceDue > 0)
                                            {
                                                <div style="font-size: 5px; color: #ef4444; font-weight: 800; margin-top: 2px;">DUES: ₹@BalanceDue.ToString("N0")</div>
                                            }
                                            else
                                            {
                                                <div style="font-size: 5px; color: #16a34a; font-weight: 800; margin-top: 2px;">PAID IN FULL</div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Entity Mapping -->
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                                        <div>
                                            <div style="font-size: 5px; color: #64748b; font-weight: 800; text-transform: uppercase;">BILL TO</div>
                                            <div style="font-size: 7px; font-weight: 800; margin-top: 2px;">@(IsRetailMode ? RetailShopName : (SelectedCustomer?.ShopName ?? "NO ENTITY SELECTED"))</div>
                                            <div style="font-size: 5px; color: #64748b;">@(IsRetailMode ? $"{RetailCustomerName} · {RetailPhone}" : SelectedCustomer?.PhoneNumber)</div>
                                        </div>
                                        @if (IncludeGST && !string.IsNullOrEmpty(GstinValue))
                                        {
                                            <div style="text-align: right;">
                                                <div style="font-size: 5px; color: #64748b; font-weight: 800; text-transform: uppercase;">GSTIN</div>
                                                <div style="font-size: 6px; font-weight: 700; margin-top: 2px;">@GstinValue</div>
                                            </div>
                                        }
                                    </div>

                                    <!-- Audit Ledger Table -->
                                    <table style="width: 100%; border-collapse: collapse; margin-top: 8px;">
                                        <thead>
                                            <tr style="border-bottom: 1px solid #e2e8f0;">
                                                <th style="text-align: left; padding: 4px 0; font-size: 5px; color: #64748b; text-transform: uppercase;">Item</th>
                                                <th style="text-align: right; padding: 4px 0; font-size: 5px; color: #64748b; text-transform: uppercase;">Qty</th>
                                                <th style="text-align: right; padding: 4px 0; font-size: 5px; color: #64748b; text-transform: uppercase;">Amt</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var r in BillRows.Where(x => x.SelectedMaterial != null).Take(8))
                                            {
                                                <tr style="border-bottom: 1px dashed #f1f5f9;">
                                                    <td style="padding: 4px 0; font-size: 6px; font-weight: 600;">@r.SelectedMaterial?.Name</td>
                                                    <td style="padding: 4px 0; font-size: 6px; text-align: right;">@r.Quantity.ToString("N0")</td>
                                                    <td style="padding: 4px 0; font-size: 6px; text-align: right; font-weight: 700;">₹ @r.TotalPrice.ToString("N0")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>

                                    <!-- Fiscal Finalization -->
                                    <div style="margin-top: 12px; padding-top: 8px; border-top: 1px solid #e2e8f0; text-align: right;">
                                        @if (IncludeGST)
                                        {
                                            <div style="font-size: 5px; color: #64748b; margin-bottom: 2px;">GST (9% + 9%): ₹ @((CGSTAmount + SGSTAmount).ToString("N0"))</div>
                                        }
                                        @if (BhadaAmount > 0)
                                        {
                                            <div style="font-size: 5px; color: #64748b; margin-bottom: 2px;">Logistics: ₹ @BhadaAmount.ToString("N0")</div>
                                        }
                                        <div style="font-size: 9px; font-weight: 900; color: var(--mud-palette-primary); border-top: 2px solid var(--mud-palette-primary); display: inline-block; padding-top: 4px; margin-top: 4px;">₹ @GrandTotal.ToString("N0")</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Stock Pulse Indicators -->
                    <div class="terra-card mt-4" style="padding: 16px;">
                        <span class="section-headline">Warehouse Pulse</span>
                        @if (!BillRows.Any(r => r.SelectedMaterial != null))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; text-align: center; font-style: italic; font-size: 0.65rem;">Resource telemetry.</MudText>
                        }
                        <MudStack Spacing="2">
                            @foreach (var row in BillRows.Where(r => r.SelectedMaterial != null))
                            {
                                <div>
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 2px;">
                                        <MudText Typo="Typo.caption" Style="font-weight: 800; font-size: 0.65rem;">@row.SelectedMaterial!.Name</MudText>
                                        <MudText Typo="Typo.caption" Style="font-weight: 900; font-size: 0.65rem;" Color="Color.Primary">@row.SelectedMaterial.StockMT KG</MudText>
                                    </div>
                                    <MudProgressLinear Color="Color.Primary" Value="@((double)row.SelectedMaterial.StockMT)" Max="20000" Rounded="true" Size="Size.Small" />
                                </div>
                            }
                        </MudStack>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
        <div class="main-canvas mt-8 pb-10">
            <div class="terra-card" style="padding: 24px; border: 1px solid rgba(255, 255, 255, 0.1); background: var(--mud-palette-surface); box-shadow: 0 4px 25px rgba(0,0,0,0.3);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 950; letter-spacing: 1px; color: var(--mud-palette-text-primary);">PENDING DRAFTS</MudText>
                        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Unfinished fiscal audits in your queue.</MudText>
                    </div>
                    <MudButton StartIcon="@Icons.Material.Filled.Refresh" Color="Color.Info" Variant="Variant.Text" OnClick="LoadDrafts" Size="Size.Small" Style="font-weight: 800;">Synchronize Queue</MudButton>
                </div>

                <MudTable Items="@DraftBills" Hover="true" Elevation="0" Dense="true" Style="background: transparent;">
                    <HeaderContent>
                        <MudTh Style="font-size: 0.65rem; font-weight: 900; color: #f59e0b; text-transform: uppercase; letter-spacing: 0.05em;">Draft ID</MudTh>
                        <MudTh Style="font-size: 0.65rem; font-weight: 900; color: #f59e0b; text-transform: uppercase; letter-spacing: 0.05em;">Shop / Entity</MudTh>
                        <MudTh Style="font-size: 0.65rem; font-weight: 900; color: #f59e0b; text-transform: uppercase; letter-spacing: 0.05em;">Date</MudTh>
                        <MudTh Style="font-size: 0.65rem; font-weight: 900; color: #f59e0b; text-transform: uppercase; letter-spacing: 0.05em; text-align: right;">Total (₹)</MudTh>
                        <MudTh Style="font-size: 0.65rem; font-weight: 900; color: #f59e0b; text-transform: uppercase; letter-spacing: 0.05em; text-align: right;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="font-family: 'JetBrains Mono', monospace; font-weight: 800; color: var(--mud-palette-primary); padding: 12px 8px;">@context.BillNumber</MudTd>
                        <MudTd Style="font-weight: 800; color: var(--mud-palette-text-primary);">@(string.IsNullOrEmpty(context.ShopName) ? "Quick/Retail Draft" : context.ShopName)</MudTd>
                        <MudTd Style="font-size: 0.8rem; color: var(--mud-palette-text-secondary);">@context.BillDate.ToString("dd MMM yyyy")</MudTd>
                        <MudTd Style="text-align: right; font-weight: 900; color: #10b981; font-family: 'JetBrains Mono', monospace;">₹@context.GrandTotal.ToString("N0")</MudTd>
                        <MudTd Style="text-align: right;">
                            <div style="display: flex; justify-content: flex-end; gap: 8px;">
                                <MudIconButton Icon="@Icons.Material.Filled.Autorenew" Size="Size.Small" Color="Color.Success" Title="Resume Audit" OnClick="() => ResumeDraft(context)" Style="background: rgba(16,185,129,0.1);" />
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Small" Color="Color.Error" Title="Discard" OnClick="() => DeleteDraft(context.Id)" Style="background: rgba(244,63,94,0.1);" />
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="pa-12 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.History" Style="color: var(--mud-palette-divider); font-size: 64px;" />
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-disabled);" Class="mt-4">The draft queue is currently empty.</MudText>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </div>
</div>

@code {
    // ── Data ────────────────────────────────────────────────
    private List<CustomerDto> CustomerList = new();
    private List<MaterialDto> MaterialList = new();

    // ── Customer Binding ────────────────────────────────────
    private CustomerDto? SelectedCustomer;
    private bool IsRetailMode = false;
    private string RetailShopName = "";
    private string RetailCustomerName = "";
    private string RetailPhone = "";
    private string GstinValue = "";
    private DateTime? BillDate = DateTime.Today;
    private decimal CashAmount = 0;
    private decimal AccountAmount = 0;

    // ── Bill Options ─────────────────────────────────────────
    private bool IncludeGST = false;
    private decimal BhadaAmount = 0;
    private decimal LabourRate = 25; // ₹ per quintal (100 kg)

    // ── Material Rows ───────────────────────────────────────
    private List<BillRow> BillRows = new() { new BillRow() };

    // ── Computed Totals ─────────────────────────────────────
    private decimal TotalQuantityKg   => BillRows.Sum(r => r.Quantity);
    private decimal LabourAmount      => Math.Round((TotalQuantityKg / 100m) * LabourRate, 2);
    private decimal SubTotal          => BillRows.Sum(r => r.TotalPrice);
    private decimal CGSTAmount        => IncludeGST ? Math.Round(SubTotal * 0.09m, 2) : 0;
    private decimal SGSTAmount        => IncludeGST ? Math.Round(SubTotal * 0.09m, 2) : 0;
    private decimal PreRoundTotal     => SubTotal + CGSTAmount + SGSTAmount + BhadaAmount + LabourAmount;
    private decimal RoundingAdjustment => Math.Round(PreRoundTotal) - PreRoundTotal;
    private decimal GrandTotal        => PreRoundTotal + RoundingAdjustment;
    private decimal BalanceDue        => GrandTotal - (CashAmount + AccountAmount);

    // ── Preview Toggle ───────────────────────────────────────
    private bool ShowPreview = false;
    private void TogglePreview() => ShowPreview = !ShowPreview;

    private List<BillDto> DraftBills = new();
    private Guid? ActiveBillId;

    // ── Lifecycle ───────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();
        await LoadDrafts();
    }

    private async Task LoadInitialData()
    {
        try { CustomerList = await CustomerService.GetCustomersAsync(); } catch { }
        try { MaterialList = await InventoryService.GetMaterialsAsync(); } catch { }
    }

    private async Task LoadDrafts()
    {
        try 
        { 
            var all = await BillService.GetBillsAsync();
            DraftBills = all.Where(b => b.Status == "Draft").Take(10).ToList();
        } 
        catch { }
    }

    // ── Stock UI Helpers ─────────────────────────────────────
    private bool IsLowStock(BillRow row) => row.SelectedMaterial!.StockMT < 500;
    private string GetBarColor(BillRow row) => IsLowStock(row) ? "var(--mud-palette-error)" : "var(--mud-palette-primary)";
    private string GetStockIconStyle(BillRow row)
    {
        var bg = IsLowStock(row) ? "rgba(255,180,171,0.1)" : "rgba(110,229,145,0.1)";
        return $"height:40px;width:40px;border-radius:4px;background:{bg};display:flex;align-items:center;justify-content:center;flex-shrink:0;";
    }
    private string GetStockIconColor(BillRow row)
    {
        var c = GetBarColor(row);
        return $"color:{c};font-size:20px;";
    }
    private string GetStockBarStyle(BillRow row)
    {
        var pct = Math.Min(100, (int)(row.SelectedMaterial!.StockMT / 20000 * 100));
        return $"background:{GetBarColor(row)};height:4px;border-radius:4px;width:{pct}%;";
    }
    private string GetStockLabel(BillRow row)
    {
        var prefix = IsLowStock(row) ? "⚠ Low Stock: " : "";
        return $"{prefix}{row.SelectedMaterial!.StockMT} KG in stock";
    }

    // ── Customer Search & Auto-fill ─────────────────────────
    private Task<IEnumerable<CustomerDto>> SearchCustomers(string search, CancellationToken _)
    {
        if (string.IsNullOrWhiteSpace(search))
            return Task.FromResult(CustomerList.Take(20).AsEnumerable());

        var results = CustomerList
            .Where(c => c.ShopName.Contains(search, StringComparison.OrdinalIgnoreCase)
                     || c.PhoneNumber.Contains(search, StringComparison.OrdinalIgnoreCase)
                     || c.CustomerName.Contains(search, StringComparison.OrdinalIgnoreCase))
            .Take(10);

        return Task.FromResult(results.AsEnumerable());
    }

    private void OnCustomerSelected(CustomerDto? customer)
    {
        SelectedCustomer = customer;
        BhadaAmount = customer?.Bhada ?? 0;   // auto-fill from customer's default bhada rate
        StateHasChanged();
    }

    private void ToggleRetailMode()
    {
        IsRetailMode = !IsRetailMode;
        if (IsRetailMode)
        {
            SelectedCustomer = null; 
            if (string.IsNullOrEmpty(RetailShopName)) RetailShopName = "KHUDRA SALE";
            if (string.IsNullOrEmpty(RetailCustomerName)) RetailCustomerName = "CASH CUSTOMER";
            BhadaAmount = 0;
        }
    }

    // ── Material Search ─────────────────────────────────────
    private Task<IEnumerable<MaterialDto>> SearchMaterials(string search, CancellationToken _)
    {
        if (string.IsNullOrWhiteSpace(search))
            return Task.FromResult(MaterialList.Take(20).AsEnumerable());

        var results = MaterialList
            .Where(m => m.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
                     || m.Shape.Contains(search, StringComparison.OrdinalIgnoreCase)
                     || m.CategoryName.Contains(search, StringComparison.OrdinalIgnoreCase))
            .Take(10);

        return Task.FromResult(results.AsEnumerable());
    }

    private void OnMaterialSelected(BillRow row, MaterialDto? material)
    {
        row.SelectedMaterial = material;
        if (material != null)
        {
            row.UnitPrice = material.GlobalRate;
            row.TaxPercentage = 18;
        }
        RecalcRow(row);
    }

    // ── Row Management ──────────────────────────────────────
    private void AddRow() => BillRows.Add(new BillRow());
    private void RemoveRow(BillRow row) { if (BillRows.Count > 1) BillRows.Remove(row); }

    private void RecalcRow(BillRow row)
    {
        row.TotalPrice = Math.Round(row.Quantity * row.UnitPrice, 2);
        StateHasChanged();
    }

    // ── Actions ─────────────────────────────────────────────
    private string? GeneratedBillNumber;
    private bool IsSaving = false;

    private async Task GenerateInvoice() => await SubmitBill("Pending");
    private async Task SaveAsDraft()     => await SubmitBill("Draft");

    private async Task SubmitBill(string status)
    {
        if (!IsRetailMode && SelectedCustomer == null) { Snackbar.Add("Please select a customer.", Severity.Warning); return; }
        if (IsRetailMode && string.IsNullOrEmpty(RetailShopName)) { Snackbar.Add("Please enter a retail shop name.", Severity.Warning); return; }
        if (!BillRows.Any(r => r.SelectedMaterial != null && r.Quantity > 0)) { Snackbar.Add("Add at least one material with quantity.", Severity.Warning); return; }

        // Stock Validation (Only for non-draft finalized invoices)
        if (status != "Draft")
        {
            foreach (var row in BillRows.Where(r => r.SelectedMaterial != null))
            {
                if (row.Quantity > row.SelectedMaterial!.StockMT)
                {
                    Snackbar.Add($"INSUFFICIENT STOCK: '{row.SelectedMaterial.Name}' only has {row.SelectedMaterial.StockMT} KG available.", Severity.Error);
                    return;
                }
            }
        }

        IsSaving = true;
        try
        {
            Guid finalCustomerId = Guid.Empty;
            if (IsRetailMode)
            {
                var khudra = CustomerList.FirstOrDefault(c => c.ShopName.ToUpper().Contains("KHUDRA"));
                if (khudra == null)
                {
                    // Fetch roles to get a valid one
                    var roles = await UserService.GetRolesAsync();
                    var targetRole = roles.FirstOrDefault(r => r.Name.Contains("Customer", StringComparison.OrdinalIgnoreCase)) ?? roles.FirstOrDefault();
                    
                    if (targetRole == null)
                    {
                        Snackbar.Add("Infrastructure Error: No Roles defined in system. Please create a role first.", Severity.Error);
                        return;
                    }

                    var newKhudra = new CustomerDto
                    {
                        FirstName = "RETAIL",
                        LastName = "SALE",
                        Email = $"khudra.{Guid.NewGuid().ToString().Substring(0, 4)}@vias.com",
                        RoleId = targetRole.Id,
                        ShopName = "KHUDRA SALE",
                        CustomerName = "Retail/Cash",
                        PhoneNumber = "0000000000",
                        IsActive = true
                    };
                    await CustomerService.CreateCustomerAsync(newKhudra);
                    CustomerList = await CustomerService.GetCustomersAsync();
                    khudra = CustomerList.FirstOrDefault(c => c.ShopName.ToUpper().Contains("KHUDRA"));
                }
                finalCustomerId = khudra?.Id ?? Guid.Empty;
            }
            else
            {
                finalCustomerId = SelectedCustomer!.Id;
            }

            if (finalCustomerId == Guid.Empty)
            {
                Snackbar.Add("Could not resolve Customer Identity. Please contact support.", Severity.Error);
                return;
            }

            var bill = new BillDto
            {
                Id           = ActiveBillId ?? Guid.Empty,
                CustomerId   = finalCustomerId,
                BillDate     = BillDate ?? DateTime.Today,
                SubTotal     = SubTotal,
                CGSTAmount   = CGSTAmount,
                SGSTAmount   = SGSTAmount,
                IGSTAmount   = 0,
                BhadaAmount  = BhadaAmount,
                LabourAmount = LabourAmount,
                RoundingAdjustment = RoundingAdjustment,
                GrandTotal   = GrandTotal,
                CashPaid     = CashAmount,
                AmountPaid   = AccountAmount,
                BalanceDue   = GrandTotal - (CashAmount + AccountAmount),
                TotalWeightKg = TotalQuantityKg,
                Notes        = IsRetailMode ? $"[RETAIL: {RetailShopName} / {RetailCustomerName}] {GstinValue}" : GstinValue,
                Status       = status,
                Items        = BillRows
                    .Where(r => r.SelectedMaterial != null && r.Quantity > 0)
                    .Select(r => new BillItemDto
                    {
                        MaterialId    = r.SelectedMaterial!.Id,
                        MaterialName  = r.SelectedMaterial.Name,
                        Quantity      = r.Quantity,
                        UnitPrice     = r.UnitPrice,
                        TaxPercentage = r.TaxPercentage,
                        TotalPrice    = r.TotalPrice
                    }).ToList()
            };

            if (ActiveBillId != null)
            {
                await BillService.UpdateBillAsync(bill);
                Snackbar.Add($"Updated Draft — {GeneratedBillNumber}", Severity.Success);
            }
            else
            {
                var result = await BillService.CreateBillAsync(bill);
                GeneratedBillNumber = result.BillNumber;
                ActiveBillId = result.InsertedId;
                Snackbar.Add(status == "Draft" ? $"Draft saved — {GeneratedBillNumber}" : $"Invoice {GeneratedBillNumber} generated!", Severity.Success);
            }

            await LoadDrafts(); // Refresh bottom grid
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error, config => config.SnackbarVariant = Variant.Filled);
        }
        finally { IsSaving = false; }
    }

    private async Task ResumeDraft(BillDto draft)
    {
        try
        {
            var fullBill = await BillService.GetBillByIdAsync(draft.Id);
            ActiveBillId = fullBill.Id;
            SelectedCustomer = CustomerList.FirstOrDefault(c => c.Id == fullBill.CustomerId);
            BillDate = fullBill.BillDate;
            GstinValue = fullBill.Notes;
            GeneratedBillNumber = fullBill.BillNumber;
            CashAmount = fullBill.CashPaid;
            AccountAmount = fullBill.AmountPaid;
            BhadaAmount = fullBill.BhadaAmount;

            BillRows.Clear();
            foreach (var item in fullBill.Items)
            {
                var mat = MaterialList.FirstOrDefault(m => m.Id == item.MaterialId);
                BillRows.Add(new BillRow 
                { 
                    SelectedMaterial = mat,
                    Quantity = item.Quantity,
                    UnitPrice = item.UnitPrice,
                    TaxPercentage = item.TaxPercentage,
                    TotalPrice = item.TotalPrice
                });
            }
            if (!BillRows.Any()) BillRows.Add(new BillRow());
            
            Snackbar.Add($"Resumed Draft {fullBill.BillNumber}", Severity.Info);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not resume draft: {ex.Message}", Severity.Error);
        }
    }

    private void StartNewTransaction()
    {
        ActiveBillId = null;
        GeneratedBillNumber = null;
        SelectedCustomer = null;
        IsRetailMode = false;
        RetailShopName = "";
        RetailCustomerName = "";
        RetailPhone = "";
        BillDate = DateTime.Today;
        GstinValue = "";
        BillRows = new() { new BillRow() };
        CashAmount = 0;
        AccountAmount = 0;
        BhadaAmount = 0;
        Snackbar.Add("Canvas cleared. New transaction started.", Severity.Normal);
        StateHasChanged();
    }

    private async Task DeleteDraft(Guid id)
    {
        var ok = await BillService.DeleteBillAsync(id);
        if (ok) 
        {
            Snackbar.Add("Draft deleted", Severity.Warning);
            await LoadDrafts();
        }
    }


    private async Task DownloadBill()
    {
        if (!IsRetailMode && SelectedCustomer == null) { Snackbar.Add("Please select a customer first.", Severity.Warning, config => config.SnackbarVariant = Variant.Filled); return; }
        if (IsRetailMode && string.IsNullOrEmpty(RetailShopName)) { Snackbar.Add("Please enter retail details.", Severity.Warning); return; }
        if (!BillRows.Any(r => r.SelectedMaterial != null && r.Quantity > 0)) { Snackbar.Add("Add at least one material with quantity.", Severity.Warning); return; }

        // Auto-save first if not yet generated so we always have a real bill number
        if (string.IsNullOrEmpty(GeneratedBillNumber))
        {
            await SubmitBill("Pending");
            if (string.IsNullOrEmpty(GeneratedBillNumber)) return; // save failed
        }

        var html = BuildInvoiceHtml();
        await JS.InvokeVoidAsync("vikashPrint", html);
    }

    private string BuildInvoiceHtml()
    {
        var sb = new System.Text.StringBuilder();
        var rows = BillRows.Where(r => r.SelectedMaterial != null && r.Quantity > 0).ToList();

        sb.Append("<!DOCTYPE html><html><head><meta charset='utf-8'><style>");
        sb.Append("body{font-family:'Segoe UI',sans-serif;color:#1e293b;padding:40px;max-width:850px;margin:0 auto;background:#fff;}");
        sb.Append("h1{font-size:26px;font-weight:900;margin:0;color:#0f172a;}");
        sb.Append(".subtitle{font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.15em;font-weight:700;}");
        sb.Append("table{width:100%;border-collapse:collapse;margin-top:24px;border:1px solid #e2e8f0;}");
        sb.Append("th{background:#f8fafc;padding:12px 8px;text-align:left;font-size:11px;text-transform:uppercase;color:#475569;border-bottom:2px solid #cbd5e1;font-weight:800;}");
        sb.Append("th:not(:first-child){text-align:right;}");
        sb.Append("td{padding:10px 8px;border-bottom:1px solid #f1f5f9;font-size:13px;}");
        sb.Append(".totals-container{margin-top:32px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;}");
        sb.Append(".payment-info{background:#f8fafc;padding:16px;border-radius:8px;border:1px solid #e2e8f0;}");
        sb.Append(".totals-card{display:flex;flex-direction:column;align-items:flex-end;gap:6px;}");
        sb.Append(".grand{font-size:24px;font-weight:900;color:#059669;margin-top:8px;}");
        sb.Append(".words{margin-top:24px;font-style:italic;font-size:12px;color:#64748b;border-left:3px solid #cbd5e1;padding-left:12px;}");
        sb.Append(".footer{margin-top:64px;text-align:center;font-size:11px;color:#94a3b8;border-top:1px solid #f1f5f9;padding-top:20px;}");
        sb.Append("</style></head><body>");

        // Header Section
        sb.Append("<div style='display:flex;justify-content:space-between;align-items:flex-start;border-bottom:3px solid #0f172a;padding-bottom:20px;'>");
        sb.Append("<div><div class='subtitle'>Tax Invoice / लेखा विवरण</div><h1>VIKASH IRON AND STEEL PVT LTD</h1>");
        sb.Append("<div style='font-size:13px;color:#475569;margin-top:6px;font-weight:500;'>Ekma Parsa Road, 841208 | Mob: 9631691290 | State: Bihar (10)</div></div>");
        sb.Append("<div style='text-align:right;'>");
        sb.Append($"<div style='font-size:22px;font-weight:900;color:#0f172a;'>{GeneratedBillNumber ?? "PENDING-DRAFT"}</div>");
        sb.Append($"<div style='font-size:14px;color:#475569;font-weight:600;'>Date: {BillDate?.ToString("dd MMMM yyyy")}</div>");
        sb.Append("</div></div>");

        // Client Section
        sb.Append("<div style='display:grid;grid-template-columns:1fr 1fr;margin:32px 0;gap:20px;'>");
        sb.Append("<div><div class='subtitle'>Bill To (ग्राहक)</div>");
        sb.Append($"<div style='font-size:18px;font-weight:800;margin-top:8px;color:#0f172a;'>{SelectedCustomer?.ShopName}</div>");
        sb.Append($"<div style='color:#334155;font-size:13px;font-weight:600;'>{SelectedCustomer?.CustomerName}</div>");
        sb.Append($"<div style='color:#64748b;font-size:13px;'>{SelectedCustomer?.PhoneNumber}</div>");
        sb.Append($"<div style='color:#64748b;font-size:13px;margin-top:4px;'>{SelectedCustomer?.ShopAddress}</div></div>");
        
        if (IncludeGST && !string.IsNullOrEmpty(GstinValue))
            sb.Append($"<div style='text-align:right;'><div class='subtitle'>GSTIN / UIN</div><div style='margin-top:8px;font-weight:800;font-size:15px;color:#0f172a;'>{GstinValue}</div></div>");
        sb.Append("</div>");

        // Table header
        sb.Append("<table><thead><tr>");
        sb.Append("<th>ITEM DESCRIPTION</th><th style='text-align:right;'>QTY (KG)</th><th style='text-align:right;'>RATE/KG</th>");
        if (IncludeGST) sb.Append("<th style='text-align:right;'>GST%</th>");
        sb.Append("<th style='text-align:right;'>LINE TOTAL</th>");
        sb.Append("</tr></thead><tbody>");

        // Table rows
        foreach (var r in rows)
        {
            sb.Append("<tr>");
            sb.Append($"<td style='font-weight:600;'>{r.SelectedMaterial!.Name} <span style='font-weight:400;color:#64748b;'>({r.SelectedMaterial.Shape})</span></td>");
            sb.Append($"<td style='text-align:right;font-family:monospace;'>{r.Quantity:N3}</td>");
            sb.Append($"<td style='text-align:right;font-family:monospace;'>₹{r.UnitPrice:N2}</td>");
            if (IncludeGST) sb.Append($"<td style='text-align:right;font-family:monospace;'>{r.TaxPercentage}%</td>");
            sb.Append($"<td style='text-align:right;font-weight:700;font-family:monospace;'>₹{r.TotalPrice:N2}</td>");
            sb.Append("</tr>");
        }
        sb.Append("</tbody></table>");

        // Weight Case Summary
        sb.Append($"<div style='margin-top:12px;font-size:12px;font-weight:800;text-align:right;color:#475569;'>Total Weight (Case): <span style='color:#0f172a;background:#f1f5f9;padding:4px 8px;border-radius:4px;'>{TotalQuantityKg:N3} KG</span></div>");

        // Totals & Payments Section
        sb.Append("<div class='totals-container'>");
        
        // Payment Realization Info (Left Column)
        sb.Append("<div class='payment-info'>");
        sb.Append("<div class='subtitle' style='margin-bottom:12px;'>Payment Realization / भुगतान</div>");
        sb.Append($"<div style='display:flex;justify-content:space-between;margin-bottom:6px;'><span style='font-size:13px;color:#475569;'>Cash (Liquid):</span> <span style='font-weight:700;font-family:monospace;'>₹{CashAmount:N2}</span></div>");
        sb.Append($"<div style='display:flex;justify-content:space-between;margin-bottom:6px;'><span style='font-size:13px;color:#475569;'>A/C (Bank):</span> <span style='font-weight:700;font-family:monospace;'>₹{AccountAmount:N2}</span></div>");
        var bal = GrandTotal - (CashAmount + AccountAmount);
        sb.Append($"<div style='display:flex;justify-content:space-between;border-top:1px solid #e2e8f0;padding-top:6px;color:{(bal > 0 ? "#ef4444" : "#059669")};'>");
        sb.Append($"<span style='font-size:13px;font-weight:800;'>Balance Due (बकाया):</span> <span style='font-weight:900;font-family:monospace;'>₹{bal:N2}</span></div>");
        
        if (bal > 0)
        {
            sb.Append("<div style='margin-top:20px; text-align:center; background:#fff; padding:12px; border:1px dashed #673ab7; border-radius:8px;'>");
            sb.Append("<div style='font-size:9px; font-weight:900; color:#673ab7; margin-bottom:10px;'>DIGITAL PAYMENT OPTION (UPI)</div>");
            sb.Append($"<img src='https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=upi://pay?pa=risham123sharma@ybl%26pn=Vikash%20Iron%26am={bal}%26cu=INR' style='width:100px; height:100px;' />");
            sb.Append("<div style='font-size:11px; font-weight:800; font-family:monospace; margin-top:8px;'>risham123sharma@ybl</div>");
            sb.Append("</div>");
        }
        sb.Append("</div>");

        // Calculations Card (Right Column)
        sb.Append("<div class='totals-card'>");
        sb.Append($"<div style='font-size:14px;color:#475569;'>Subtotal: <span style='font-weight:700;font-family:monospace;'>₹{SubTotal:N2}</span></div>");
        if (IncludeGST)
        {
            sb.Append($"<div style='font-size:13px;color:#64748b;'>CGST (9%): <span style='font-family:monospace;'>₹{CGSTAmount:N2}</span></div>");
            sb.Append($"<div style='font-size:13px;color:#64748b;'>SGST (9%): <span style='font-family:monospace;'>₹{SGSTAmount:N2}</span></div>");
        }
        if (BhadaAmount > 0)
            sb.Append($"<div style='font-size:13px;color:#64748b;'>Bhada (Transport): <span style='font-family:monospace;'>₹{BhadaAmount:N2}</span></div>");
        if (LabourAmount > 0)
            sb.Append($"<div style='font-size:13px;color:#64748b;'>Labour Weight Charge: <span style='font-family:monospace;'>₹{LabourAmount:N2}</span></div>");
        if (RoundingAdjustment != 0)
            sb.Append($"<div style='font-size:13px;color:#64748b;'>Rounding: <span style='font-family:monospace;'>₹{RoundingAdjustment:N2}</span></div>");
        sb.Append($"<div class='grand' style='font-size:24px; font-weight:900; color:#059669; margin-top:8px;'>Grand Total: ₹{GrandTotal:N2}</div>");
        sb.Append("</div></div>");

        // Amount in Words
        sb.Append($"<div class='words'><strong>Amount in Words:</strong> {NumberToWords((long)GrandTotal)} Rupees Only</div>");

        sb.Append("<div class='footer'>This is a computer generated document. &mdash; Vikash Iron and Steel Private Limited</div>");
        sb.Append("</body></html>");
        return sb.ToString();
    }

    private string NumberToWords(long number)
    {
        if (number == 0) return "Zero";
        if (number < 0) return "Minus " + NumberToWords(Math.Abs(number));
        string words = "";
        if ((number / 10000000) > 0) { words += NumberToWords(number / 10000000) + " Crore "; number %= 10000000; }
        if ((number / 100000) > 0) { words += NumberToWords(number / 100000) + " Lakh "; number %= 100000; }
        if ((number / 1000) > 0) { words += NumberToWords(number / 1000) + " Thousand "; number %= 1000; }
        if ((number / 100) > 0) { words += NumberToWords(number / 100) + " Hundred "; number %= 100; }
        if (number > 0)
        {
            if (words != "") words += "and ";
            var unitsMap = new[] { "Zero", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine", "Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen", "Seventeen", "Eighteen", "Nineteen" };
            var tensMap = new[] { "Zero", "Ten", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety" };
            if (number < 20) words += unitsMap[number];
            else
            {
                words += tensMap[number / 10];
                if ((number % 10) > 0) words += "-" + unitsMap[number % 10];
            }
        }
        return words.Trim();
    }

