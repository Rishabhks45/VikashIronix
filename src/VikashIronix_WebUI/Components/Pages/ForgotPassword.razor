@page "/forgot-password"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@layout LoginLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject VikashIronix_WebUI.Services.AuthServices.Interfaces.IAuthService AuthService

<PageTitle>Recover Access - Vikash Iron Executive Suite</PageTitle>

<div style="min-height: 100vh; background: #0d0f0d; display: flex; flex-direction: column;">

    <!-- Top Bar -->
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px 28px; background: #141614; border-bottom: 1px solid #222522;">
        <MudText Typo="Typo.body2" Style="color: #bdcabc; font-family: 'Manrope'; font-weight: 600; letter-spacing: 0.03em;">Iron Forge Admin</MudText>
        <div style="display: flex; gap: 12px; align-items: center;">
            <MudIconButton Icon="@Icons.Material.Outlined.Language" Style="color: #6b726a;" Size="Size.Small" />
            <MudIconButton Icon="@Icons.Material.Outlined.HelpOutline" Style="color: #6b726a;" Size="Size.Small" />
        </div>
    </div>

    <!-- Main Content (centered) -->
    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px 16px;">

        <!-- Brand Header -->
        <div style="text-align: center; margin-bottom: 28px;">
            <MudText Style="font-family: 'Manrope'; font-size: 1.9rem; font-weight: 900; color: #e8eae8; letter-spacing: 0.08em; line-height: 1;">VIKASH IRON</MudText>
            <MudText Style="font-family: 'Manrope'; font-size: 0.65rem; font-weight: 700; color: #6ee591; letter-spacing: 0.3em; margin-top: 3px;">EXECUTIVE SUITE</MudText>
        </div>

        <!-- Forgot Password Card -->
        <div style="width: 100%; max-width: 370px; background: #181b18; border: 1px solid #252825; border-radius: 10px; padding: 28px;">
            <MudText Typo="Typo.h6" Style="font-family: 'Manrope'; font-weight: 700; color: #e2e2e2; margin-bottom: 4px;">Recover Access</MudText>
            <MudText Typo="Typo.caption" Style="color: #6b726a; display: block; margin-bottom: 22px;">Enter your registered operational email address to recover access.</MudText>

            @if (!string.IsNullOrEmpty(FeedbackMsg))
            {
                var background = IsSuccess ? "#11261a" : "#2a1212";
                var border = IsSuccess ? "#6ee591" : "#cf6679";
                <MudAlert Severity="@(IsSuccess ? Severity.Success : Severity.Error)" Dense="true" Class="mb-4" Style=$"background: {background}; border: 1px solid {border}; font-size: 0.8rem; border-radius: 6px;">
                    @FeedbackMsg
                </MudAlert>
            }

            <MudStack Spacing="0">
                <!-- Username field -->
                <div style="margin-bottom: 24px;">
                    <MudText Style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: #6b726a; margin-bottom: 6px; display: block;">REGISTERED EMAIL</MudText>
                    <MudTextField @bind-Value="Email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Placeholder="j.smith@vikashiron.com"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Margin="Margin.Dense"
                                  Style="--mud-palette-lines-inputs: #2a2e2a;"
                                  FullWidth="true" />
                </div>

                <!-- Submit Button -->
                <MudButton Variant="Variant.Filled"
                           FullWidth="true"
                           OnClick="HandleRecovery"
                           Style="background: #e8eae8; color: #001209; font-family: 'Manrope'; font-weight: 800; letter-spacing: 0.12em; border-radius: 6px; padding: 12px; font-size: 0.82rem; margin-bottom: 12px;">
                    @if (IsLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color: #001209; margin-right: 8px;" />
                        <span>PROCESSING...</span>
                    }
                    else
                    {
                        <span>SEND RECOVERY LINK</span>
                    }
                </MudButton>
                
                <MudButton Variant="Variant.Text" FullWidth="true" OnClick="@(() => Nav.NavigateTo("/login"))" Style="color: #6b726a; font-size: 0.78rem;">
                    RETURN TO LOGIN
                </MudButton>

            </MudStack>
        </div>
    </div>

    <!-- Footer -->
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px 28px; background: #141614; border-top: 1px solid #222522;">
        <MudText Style="font-size: 0.72rem; color: #484e48;">&#169; 2024 Iron Forge Industrial. All rights reserved.</MudText>
        <div style="display: flex; gap: 20px;">
            <MudLink Href="#" Style="font-size: 0.72rem; color: #6b726a; text-decoration: none;">Security Protocol</MudLink>
        </div>
    </div>
</div>

@code {
    string Email = "";
    bool IsLoading = false;
    string FeedbackMsg = "";
    bool IsSuccess = false;

    async Task HandleRecovery()
    {
        FeedbackMsg = "";
        IsSuccess = false;
        
        if (string.IsNullOrWhiteSpace(Email))
        {
            FeedbackMsg = "Provide a valid email address.";
            return;
        }

        IsLoading = true;
        bool result = await AuthService.ForgotPasswordAsync(Email);
        
        IsLoading = false;
        IsSuccess = true;
        FeedbackMsg = "If a matching operational account was found, a recovery link has been transmitted. Check your secure inbox.";
    }
}
