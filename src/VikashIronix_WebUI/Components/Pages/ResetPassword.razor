@page "/reset-password"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@layout LoginLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject VikashIronix_WebUI.Services.AuthServices.Interfaces.IAuthService AuthService

<PageTitle>Reset Credentials - Vikash Iron Executive Suite</PageTitle>

<div style="min-height: 100vh; background: #0d0f0d; display: flex; flex-direction: column;">

    <!-- Top Bar -->
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px 28px; background: #141614; border-bottom: 1px solid #222522;">
        <MudText Typo="Typo.body2" Style="color: #bdcabc; font-family: 'Manrope'; font-weight: 600; letter-spacing: 0.03em;">Iron Forge Admin</MudText>
    </div>

    <!-- Main Content (centered) -->
    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px 16px;">

        <!-- Brand Header -->
        <div style="text-align: center; margin-bottom: 28px;">
            <MudText Style="font-family: 'Manrope'; font-size: 1.9rem; font-weight: 900; color: #e8eae8; letter-spacing: 0.08em; line-height: 1;">VIKASH IRON</MudText>
            <MudText Style="font-family: 'Manrope'; font-size: 0.65rem; font-weight: 700; color: #6ee591; letter-spacing: 0.3em; margin-top: 3px;">EXECUTIVE SUITE</MudText>
        </div>

        <!-- Reset Password Card -->
        <div style="width: 100%; max-width: 370px; background: #181b18; border: 1px solid #252825; border-radius: 10px; padding: 28px;">
            <MudText Typo="Typo.h6" Style="font-family: 'Manrope'; font-weight: 700; color: #e2e2e2; margin-bottom: 4px;">Initialize New Key</MudText>
            <MudText Typo="Typo.caption" Style="color: #6b726a; display: block; margin-bottom: 22px;">Create a new security password compliant with protocol.</MudText>

            @if (!string.IsNullOrEmpty(FeedbackMsg))
            {
                var background = IsSuccess ? "#11261a" : "#2a1212";
                var border = IsSuccess ? "#6ee591" : "#cf6679";
                <MudAlert Severity="@(IsSuccess ? Severity.Success : Severity.Error)" Dense="true" Class="mb-4" Style=$"background: {background}; border: 1px solid {border}; font-size: 0.8rem; border-radius: 6px;">
                    @FeedbackMsg
                </MudAlert>
            }

            @if (!IsSuccess)
            {
                <MudStack Spacing="0">
                    <div style="margin-bottom: 14px;">
                        <MudText Style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: #6b726a; margin-bottom: 6px; display: block;">NEW SECURITY CREDENTIAL</MudText>
                        <MudTextField @bind-Value="Password"
                                    Variant="Variant.Outlined"
                                    InputType="@PwdType1"
                                    Adornment="Adornment.End"
                                    AdornmentIcon="@PwdIcon1"
                                    OnAdornmentClick="TogglePassword1"
                                    Margin="Margin.Dense"
                                    FullWidth="true" />
                    </div>

                    <div style="margin-bottom: 24px;">
                        <MudText Style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: #6b726a; margin-bottom: 6px; display: block;">CONFIRM CREDENTIAL</MudText>
                        <MudTextField @bind-Value="ConfirmPassword"
                                    Variant="Variant.Outlined"
                                    InputType="@PwdType2"
                                    Adornment="Adornment.End"
                                    AdornmentIcon="@PwdIcon2"
                                    OnAdornmentClick="TogglePassword2"
                                    Margin="Margin.Dense"
                                    FullWidth="true" />
                    </div>

                    <!-- Submit Button -->
                    <MudButton Variant="Variant.Filled"
                            FullWidth="true"
                            OnClick="HandleReset"
                            Style="background: #e8eae8; color: #001209; font-family: 'Manrope'; font-weight: 800; letter-spacing: 0.12em; border-radius: 6px; padding: 12px; font-size: 0.82rem; margin-bottom: 12px;">
                        @if (IsLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color: #001209; margin-right: 8px;" />
                            <span>PROCESSING...</span>
                        }
                        else
                        {
                            <span>SET NEW PASSWORD</span>
                        }
                    </MudButton>
                </MudStack>
            }
            
            @if (IsSuccess) 
            {
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(() => Nav.NavigateTo("/login"))" Style="background: #6ee591; color: #001209; font-family: 'Manrope'; font-weight: 800; letter-spacing: 0.12em; border-radius: 6px; padding: 12px; font-size: 0.82rem;">
                    PROCEED TO LOGIN
                </MudButton>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    string Password = "";
    string ConfirmPassword = "";
    bool IsLoading = false;
    string FeedbackMsg = "";
    bool IsSuccess = false;

    InputType PwdType1 = InputType.Password;
    string PwdIcon1 = Icons.Material.Filled.VisibilityOff;
    InputType PwdType2 = InputType.Password;
    string PwdIcon2 = Icons.Material.Filled.VisibilityOff;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            FeedbackMsg = "Invalid access token provided. Please return to login.";
        }
    }

    void TogglePassword1()
    {
        PwdType1 = PwdType1 == InputType.Password ? InputType.Text : InputType.Password;
        PwdIcon1 = PwdType1 == InputType.Password ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    }

    void TogglePassword2()
    {
        PwdType2 = PwdType2 == InputType.Password ? InputType.Text : InputType.Password;
        PwdIcon2 = PwdType2 == InputType.Password ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    }

    async Task HandleReset()
    {
        FeedbackMsg = "";
        IsSuccess = false;
        
        if (string.IsNullOrWhiteSpace(Token))
        {
            FeedbackMsg = "Invalid access token provided.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Password) || Password != ConfirmPassword)
        {
            FeedbackMsg = "Validation failed: Credentials do not match or are empty.";
            return;
        }

        IsLoading = true;
        try 
        {
            bool result = await AuthService.ResetPasswordAsync(Token, Password);
            if (result)
            {
                IsSuccess = true;
                FeedbackMsg = "Identity secured. Your access credential has been updated.";
            }
            else 
            {
                FeedbackMsg = "Process failed. Token may be expired or invalid.";
            }
        }
        catch (Exception)
        {
            FeedbackMsg = "A network or system error occurred integrating with the core API.";
        }
        
        IsLoading = false;
    }
}
