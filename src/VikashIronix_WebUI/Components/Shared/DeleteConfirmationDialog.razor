<MudDialog Style="background: #161916; border: 1px solid #252825; border-radius: 10px;">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Style="color: #ffb4ab;" Size="Size.Medium" />
            <MudText Typo="Typo.h6" Style="font-family: 'Manrope'; font-weight: 700; color: #e2e2e2;">@Title</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText Style="color: #bdcabc; margin-bottom: 15px;">@ContentText</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel" Style="color: #bdcabc; border-color: #2a2e2a; border-radius: 6px; padding: 6px 14px;">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" OnClick="Submit" Style="background: #ffb4ab; color: #3a0001; font-weight: 800; border-radius: 6px; padding: 6px 16px;" StartIcon="@Icons.Material.Filled.Delete">Delete Permanently</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string Title { get; set; } = "Confirm Deletion";
    [Parameter] public string ContentText { get; set; } = "Are you sure you want to delete this item?";

    void Submit() => MudDialog.Close(DialogResult.Ok(true));
    void Cancel() => MudDialog.Cancel();
}
