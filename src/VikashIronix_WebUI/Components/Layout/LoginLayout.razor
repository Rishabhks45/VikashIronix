@inherits LayoutComponentBase

<MudThemeProvider Theme="AdminTheme" IsDarkMode="true" />

<MudLayout>
    <MudMainContent Style="padding: 0;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudTheme AdminTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#6ee591",
            Background = "#121414",
            Surface = "#1a1c1c",
            AppbarBackground = "#1a1c1c",
            DrawerBackground = "#181a1a",
            TextPrimary = "#e2e2e2",
            TextSecondary = "#bdcabc",
            ActionDefault = "#6ee591",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#6ee591",
            Background = "#121414",
            Surface = "#1a1c1c",
            AppbarBackground = "#1a1c1c",
            DrawerBackground = "#181a1a",
            TextPrimary = "#e2e2e2",
            TextSecondary = "#bdcabc",
            ActionDefault = "#6ee591",
        }
    };
}
